{
  "git": {
    "commitMessage": "chore: release v${version}",
    "tagName": "v${version}",
    "requireCleanWorkingDir": true
  },
  "github": {
    "release": true,
    "releaseName": "v${version}",
    "autoGenerate": false,
    "web": true,
    "releaseNotes": "node scripts/extract-changelog.js"
  },
  "npm": {
    "publish": false
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": {
        "name": "conventionalcommits",
        "types": [
          {"type": "feat", "section": "✨ 新特性 (Features)"},
          {"type": "fix", "section": "🐛 Bug 修复 (Bug Fixes)"},
          {"type": "perf", "section": "⚡️ 性能优化 (Performance)"},
          {"type": "revert", "section": "⏪ 回滚 (Reverts)"},
          {"type": "chore", "hidden": true},
          {"type": "docs", "hidden": true},
          {"type": "style", "hidden": true},
          {"type": "refactor", "hidden": true},
          {"type": "test", "hidden": true}
        ]
      },
      "infile": "CHANGELOG.md",
      "header": "# 更新日志 (Changelog)\n\n",
      "releaseCount": 1,
      "writerOpts": {
        "headerPartial": "## v{{version}} ({{date}})\n",
        "commitPartial": "* {{#if scope}}**{{scope}}:** {{/if}}{{#if subject}}{{{subject}}}{{else}}{{{header}}}{{/if}}\n"
      }
    }
  }
}
